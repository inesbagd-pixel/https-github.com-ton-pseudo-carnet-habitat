# ----------------------------------------------------------------------------
# Carnet Habitat — variables d'environnement
# Copiez ce fichier en `.env.local` puis renseignez vos valeurs.
# ----------------------------------------------------------------------------

# URL absolue de production (sans slash final).
# Utilisée pour les canonicals, le sitemap, Open Graph, etc.
NEXT_PUBLIC_SITE_URL=https://www.carnethabitat.fr

# --- Newsletter Brevo (ex-Sendinblue) ---------------------------------------
# Laissez vide pour fonctionner en « mode démonstration » (inscription simulée).
# Renseignez ces deux variables pour activer l'inscription réelle.
BREVO_API_KEY=
BREVO_LIST_ID=
